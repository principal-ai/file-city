{
  "name": "@principal-ai/repository-abstraction",
  "version": "0.1.0",
  "description": "Repository and file system abstraction layer",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun build:clean && bun build:ts",
    "build:clean": "rm -rf dist",
    "build:ts": "bun run tsc",
    "dev": "bun run tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.4"
  },
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/principal-ai/principle-md.git",
    "directory": "packages/repository-abstraction"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/"
  }
}
