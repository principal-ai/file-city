            { "path": "tsconfig.json", "type": "file" },
            { "path": "tsconfig.base.json", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ],
      "colorMode": "fileTypes"
    },
    {
      "id": "full-picture",
      "title": "The Full Picture",
      "description": "You've now seen the complete File City engine — from data transformation through to rendering. Dive into any district to explore further!",
      "estimatedTime": 30,
      "focusDirectory": "",
      "colorMode": "fileTypes"
    }
  ],
