{
  "name": "file-city-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:builder && bun run build:react && bun run build:server",
    "build:builder": "cd packages/builder && bun run build",
    "build:react": "cd packages/react && bun run build",
    "build:server": "cd packages/server && bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "publish:all": "bun run publish:builder && bun run publish:react && bun run publish:server",
    "publish:builder": "cd packages/builder && npm publish --access restricted",
    "publish:react": "cd packages/react && npm publish --access restricted",
    "publish:server": "cd packages/server && npm publish --access restricted",
    "version:sync": "bun run version:set",
    "version:set": "echo 'Setting version...' && bun scripts/sync-versions.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
